SONG_AI_ENV=local
SONG_AI_OUTPUT_DIR=data
SONG_AI_LLAMA_CPP_BASE_URL=http://host.docker.internal:8080
SONG_AI_LLAMA_CPP_INTERPRETER_BASE_URL=http://llama-gemma:8080
SONG_AI_LLAMA_CPP_TECHNICAL_BASE_URL=http://llama-qwen:8080
SONG_AI_LLAMA_CPP_CTX_SIZE=4096
SONG_AI_GEMMA_GGUF_PATH=/app/models/llm/gemma/gemma.gguf
SONG_AI_QWEN_GGUF_PATH=/app/models/llm/qwen/qwen.gguf

# Docker bootstrap: descarga/instala dentro de volumenes Docker, no en Windows.
SONG_AI_BOOTSTRAP_ON_START=true
SONG_AI_INSTALL_LOCAL_AUDIO_DEPS=true
SONG_AI_INSTALL_ACE_STEP=true
SONG_AI_BOOTSTRAP_UPGRADE=false
SONG_AI_ACE_STEP_PACKAGE=git+https://github.com/ace-step/ACE-Step.git
SONG_AI_DOWNLOAD_MUSICGEN=false
SONG_AI_MUSICGEN_MODEL_ID=facebook/musicgen-small
SONG_AI_HF_MODEL_IDS=
# URLs directas a archivos .gguf. El bootstrap los guarda en las rutas *_GGUF_PATH.
SONG_AI_GEMMA_GGUF_URL=https://huggingface.co/second-state/gemma-2-2b-it-GGUF/resolve/main/gemma-2-2b-it-Q4_K_M.gguf
SONG_AI_QWEN_GGUF_URL=https://huggingface.co/Qwen/Qwen3-4B-GGUF/resolve/main/Qwen3-4B-Q4_K_M.gguf
SONG_AI_VOICE_MODEL_URL=
SONG_AI_PROVIDER_REPOS=

# Modo local final: estos comandos deben generar archivos WAV reales.
# El modo pro esta pausado; no se usan servicios pagos/remotos en esta fase.
SONG_AI_FULL_SONG_COMMAND=python tools/acestep_generate.py --prompt {prompt_path} --lyrics {lyrics_path} --output {output_path} --checkpoint-path /app/models/music/ace-step --duration 60 --cpu-offload true --overlapped-decode true
# Ruta alternativa por stems. Dejala vacia si usas ACE-Step como provider full-song principal.
SONG_AI_SOUNDTRACK_COMMAND=
SONG_AI_SINGING_VOICE_COMMAND=
SONG_AI_VOICE_CONVERSION_COMMAND=
SONG_AI_LOCAL_COMMAND_TIMEOUT_SECONDS=3600
SONG_AI_ALLOW_CPU_FULL_SONG=true
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=compute,utility
# Experimental: solo para hosts Linux donde Docker expone /dev/dri.
# En Docker Desktop Windows, una Intel iGPU no acelera ACE-Step/PyTorch automaticamente.
SONG_AI_IGPU_EXPERIMENTAL=false
LIBVA_DRIVER_NAME=iHD

# Ejemplo MusicGen local, requiere instalar torch transformers scipy y tener/cachear el modelo.
# SONG_AI_SOUNDTRACK_COMMAND=python tools/musicgen_generate.py --prompt {prompt_path} --output {output_path} --model facebook/musicgen-small --seconds 45

# Ejemplo practico: usar archivos locales ya generados por herramientas gratuitas instaladas en tu equipo.
# SONG_AI_SOUNDTRACK_COMMAND=python tools/use_audio_file.py --input C:\ruta\instrumental.wav --output {output_path}
# SONG_AI_SINGING_VOICE_COMMAND=python tools/use_audio_file.py --input C:\ruta\voz_cantada.wav --output {output_path}

# Ejemplo adaptador de voz cantada: reemplaza BACKEND_REAL por tu script/CLI local real.
# SONG_AI_SINGING_VOICE_COMMAND=python tools/singing_voice_generate.py --lyrics {lyrics_path} --prompt {prompt_path} --instrumental {instrumental_path} --output {output_path} --backend-command "python tools/BACKEND_REAL.py --lyrics {lyrics_path} --prompt {prompt_path} --instrumental {instrumental_path} --output {output_path}"
