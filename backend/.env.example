SONG_AI_ENV=local
SONG_AI_OUTPUT_DIR=data
SONG_AI_HF_ENABLED=false
SONG_AI_HF_DEVICE=cpu
HF_HOME=data/models/huggingface
SONG_AI_HF_INTERPRETER_MODEL=not-configured
SONG_AI_HF_LYRICS_MODEL=not-configured
SONG_AI_HF_MUSIC_MODEL=not-configured
SONG_AI_HF_VOICE_MODEL=not-configured
SONG_AI_LLAMA_CPP_ENABLED=false
SONG_AI_LLAMA_CPP_DIR=models/llama.cpp
SONG_AI_INTERPRETER_MODEL=Gemma 4 E4B IT GGUF
SONG_AI_LYRICS_MODEL=Gemma 4 E4B IT GGUF
SONG_AI_TECHNICAL_MODEL=Qwen3 4B GGUF
SONG_AI_SOUNDTRACK_MODEL=MusicGen small
SONG_AI_SINGING_VOICE_ENGINE=RVC / ACE-Step
SONG_AI_STEMS_MODEL=Demucs
SONG_AI_MIXER_ENGINE=ffmpeg
SONG_AI_MAX_LOADED_MODELS=1
