SONG_AI_ENV=local
SONG_AI_OUTPUT_DIR=data
SONG_AI_HF_ENABLED=false
SONG_AI_HF_DEVICE=cpu
HF_HOME=data/models/huggingface
SONG_AI_HF_INTERPRETER_MODEL=not-configured
SONG_AI_HF_LYRICS_MODEL=not-configured
SONG_AI_HF_MUSIC_MODEL=not-configured
SONG_AI_HF_VOICE_MODEL=not-configured
SONG_AI_LLAMA_CPP_DIR=models/llama.cpp
SONG_AI_LLAMA_CPP_BASE_URL=http://host.docker.internal:8080
SONG_AI_LLAMA_CPP_INTERPRETER_BASE_URL=http://llama-gemma:8080
SONG_AI_LLAMA_CPP_TECHNICAL_BASE_URL=http://llama-qwen:8080
SONG_AI_LLAMA_CPP_CTX_SIZE=4096
SONG_AI_GEMMA_GGUF_PATH=/app/models/llm/gemma/gemma.gguf
SONG_AI_QWEN_GGUF_PATH=/app/models/llm/qwen/qwen.gguf
SONG_AI_INTERPRETER_MODEL=Gemma 2 2B IT GGUF
SONG_AI_LYRICS_MODEL=Gemma 2 2B IT GGUF
SONG_AI_TECHNICAL_MODEL=Qwen3 4B GGUF
SONG_AI_GEMMA_GGUF_URL=https://huggingface.co/second-state/gemma-2-2b-it-GGUF/resolve/main/gemma-2-2b-it-Q4_K_M.gguf
SONG_AI_QWEN_GGUF_URL=https://huggingface.co/Qwen/Qwen3-4B-GGUF/resolve/main/Qwen3-4B-Q4_K_M.gguf
SONG_AI_SOUNDTRACK_MODEL=MusicGen small
SONG_AI_SINGING_VOICE_ENGINE=RVC / ACE-Step
SONG_AI_STEMS_MODEL=Demucs
SONG_AI_MIXER_ENGINE=ffmpeg
# Ruta recomendada para cancion final local completa. En Docker usa volumen /app/models/music/ace-step.
SONG_AI_FULL_SONG_COMMAND=python tools/acestep_generate.py --prompt {prompt_path} --lyrics {lyrics_path} --output {output_path} --checkpoint-path /app/models/music/ace-step --duration 60 --cpu-offload true --overlapped-decode true
SONG_AI_SOUNDTRACK_COMMAND=
SONG_AI_SINGING_VOICE_COMMAND=
SONG_AI_VOICE_CONVERSION_COMMAND=
SONG_AI_LOCAL_COMMAND_TIMEOUT_SECONDS=3600
SONG_AI_ALLOW_CPU_FULL_SONG=true
SONG_AI_IGPU_EXPERIMENTAL=false
LIBVA_DRIVER_NAME=iHD
SONG_AI_MAX_LOADED_MODELS=1
